{
  "manifest_version": 3,
  "name": "Job App Autofill",
  "version": "1.0",
  "description": "Fill job application forms from a profile you save once.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
